{
    "apiVersion": "v1",
    "kind": "Namespace",
    "metadata": {
       "name": "team-alpha-dev",
       "labels": {
          "company": "mycompany",
          "tenant": "tenant-a",
          "application": " app"
       }
    },
    "roleRef": {
       "apiGroup": "rbac.authorization.k8s.io",
       "kind": "ClusterRole",
       "name": "admin"
    },
    "subjects": [
       {
          "kind": "Group",
          "namespace": "team-alpha-dev",
          "name": "7345435-345345-45-99999999"
       }
    ],
    "items": [
       {
          "apiVersion": "v1",
          "kind": "ResourceQuota",
          "metadata": {
             "name": "pods-high",
             "namespace": "team-alpha-dev"
          },
          "spec": {
             "hard": {
                "cpu": "10",
                "memory": "200Gi",
                "pods": "10"
             },
             "scopeSelector": {
                "matchExpressions": [
                   {
                      "operator": "In",
                      "scopeName": "PriorityClass",
                      "values": [
                         "high"
                      ]
                   }
                ]
             }
          }
       },
       {
          "apiVersion": "v1",
          "kind": "ResourceQuota",
          "metadata": {
             "name": "pods-medium",
             "namespace": "team-alpha-dev"
          },
          "spec": {
             "hard": {
                "cpu": "5",
                "memory": "20Gi",
                "pods": "10"
             },
             "scopeSelector": {
                "matchExpressions": [
                   {
                      "operator": "In",
                      "scopeName": "PriorityClass",
                      "values": [
                         "medium"
                      ]
                   }
                ]
             }
          }
       },
       {
          "apiVersion": "v1",
          "kind": "ResourceQuota",
          "metadata": {
             "name": "pods-low",
             "namespace": "team-alpha-dev"
          },
          "spec": {
             "hard": {
                "cpu": "1",
                "memory": "10Gi",
                "pods": "10"
             },
             "scopeSelector": {
                "matchExpressions": [
                   {
                      "operator": "In",
                      "scopeName": "PriorityClass",
                      "values": [
                         "low"
                      ]
                   }
                ]
             }
          }
       },
       {
          "apiVersion": "v1",
          "kind": "ResourceQuota",
          "metadata": {
             "name": "object-quota",
             "namespace": "team-alpha-dev"
          },
          "spec": {
             "hard": {
                "pods": 50,
                "persistentvolumeclaims": 10,
                "replicationcontrollers": 0,
                "resourcequotas": 1,
                "services": 20,
                "services.loadbalancers": 0,
                "services.nodeports": 0
             }
          }
       }
    ],
    "spec": {
       "podSelector": {},
       "ingress": [
          {}
       ],
       "policyTypes": [
          "Ingress"
       ]
    }
 }